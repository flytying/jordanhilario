---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Jordan Hilario - Fingerstyle Guitar"
  description="Get in touch with Jordan Hilario for business inquiries, collaborations, custom guitar arrangements, and licensing."
>
  <section class="page-header">
    <div class="container">
      <p class="page-label">Connect</p>
      <h1>Get In Touch</h1>
      <p class="page-description">
        For business inquiries, collaborations, custom arrangements,
        or just to say hello.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <form
          class="contact-form"
          action="https://formspree.io/f/mlgojpvb"
          method="POST"
        >
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required autocomplete="name" />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" />
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Select a topic</option>
              <option value="collaboration">Collaboration</option>
              <option value="custom-arrangement">Custom Arrangement</option>
              <option value="licensing">Licensing</option>
              <option value="business">Business Inquiry</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary submit-btn">Send Message</button>
        </form>

        <aside class="contact-sidebar">
          <div class="contact-card">
            <h3>Find Me Online</h3>
            <ul class="social-links">
              <li>
                <a href="https://www.youtube.com/@JordanHilarioFingerstyle" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                  YouTube
                </a>
              </li>
              <li>
                <a href="https://www.mymusic5.com/jordanhilariofingerstyle" target="_blank" rel="noopener noreferrer">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                  </svg>
                  Guitar Tabs
                </a>
              </li>
            </ul>
          </div>

          <div class="contact-card">
            <h3>Quick Links</h3>
            <ul class="quick-links">
              <li><a href="/fingerstyle-videos">Browse Videos</a></li>
              <li><a href="https://www.mymusic5.com/jordanhilariofingerstyle" target="_blank" rel="noopener noreferrer">Get Guitar Tabs</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background-color: var(--color-bg-dark);
    color: var(--color-text-light);
    padding: 4rem 0 3rem;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .page-header h1 {
    margin-bottom: 1rem;
  }

  .page-description {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 500px;
    margin-bottom: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.875rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    color: var(--color-text);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-card {
    padding: 2rem;
    border: 1px solid var(--color-border);
  }

  .contact-card h3 {
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .social-links,
  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  .quick-links a {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
    display: block;
    padding: 0.25rem 0;
  }

  .quick-links a:hover {
    color: var(--color-text);
  }

  .submit-btn {
    align-self: flex-start;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
