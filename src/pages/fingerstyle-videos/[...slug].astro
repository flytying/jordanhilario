---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import VideoCard from '../../components/VideoCard.astro';
import { getCollection, render } from 'astro:content';
import { getYouTubeThumbnail, getYouTubeWatchUrl, getYouTubeEmbedUrl, formatDate } from '../../utils/youtube';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map((video) => ({
    params: { slug: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { Content } = await render(video);
const { title, songTitle, artist, youtubeId, publishDate, description, tags, tabUrl, duration } = video.data;

// Related videos: same tags, exclude current, limit 4
const allVideos = await getCollection('videos');
const relatedVideos = allVideos
  .filter((v) => v.id !== video.id)
  .map((v) => ({
    video: v,
    score: v.data.tags.filter((t) => tags.includes(t)).length,
  }))
  .sort((a, b) => b.score - a.score || b.video.data.publishDate.getTime() - a.video.data.publishDate.getTime())
  .slice(0, 4)
  .map((v) => v.video);

const thumbnailUrl = getYouTubeThumbnail(youtubeId, 'maxres');
const watchUrl = getYouTubeWatchUrl(youtubeId);
const embedUrl = getYouTubeEmbedUrl(youtubeId);
const formattedDate = formatDate(publishDate);
const canonicalUrl = `https://jordanhilario.com/fingerstyle-videos/${video.id}`;
---

<BaseLayout
  title={`${title} | Jordan Hilario`}
  description={description}
  ogImage={thumbnailUrl}
  canonicalUrl={canonicalUrl}
  type="video.other"
>
  <article class="video-detail">
    <!-- Video Player -->
    <div class="video-player-wrapper">
      <div class="container">
        <VideoPlayer youtubeId={youtubeId} title={title} />
      </div>
    </div>

    <!-- Video Info -->
    <div class="container">
      <div class="video-info-grid">
        <div class="video-info-main">
          <h1>{title}</h1>
          <div class="video-meta">
            <span class="video-artist">{artist}</span>
            <span class="video-date">{formattedDate}</span>
          </div>

          {tags.length > 0 && (
            <div class="video-tags">
              {tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}

          <div class="video-body">
            <Content />
          </div>

          <a href={watchUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline-dark">
            Watch on YouTube &rarr;
          </a>
        </div>

        <!-- Sidebar -->
        <aside class="video-sidebar">
          {tabUrl && (
            <div class="tab-card">
              <h3>Get the Guitar Tab</h3>
              <p>Learn to play this arrangement with accurate guitar tablature.</p>
              <a href={tabUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary" style="width:100%;justify-content:center;">
                Download Tab
              </a>
            </div>
          )}

          <div class="subscribe-card">
            <h3>More Covers</h3>
            <p>Subscribe to get notified when new covers drop.</p>
            <a href="https://www.youtube.com/@JordanHilarioFingerstyle?sub_confirmation=1" target="_blank" rel="noopener noreferrer" class="btn btn-outline-dark" style="width:100%;justify-content:center;">
              Subscribe
            </a>
          </div>
        </aside>
      </div>
    </div>

    <!-- Related Videos -->
    {relatedVideos.length > 0 && (
      <section class="related-section section">
        <div class="container">
          <h2 class="section-title">More Covers</h2>
          <div class="video-grid">
            {relatedVideos.map((rv) => (
              <VideoCard
                slug={rv.id}
                title={rv.data.title}
                artist={rv.data.artist}
                youtubeId={rv.data.youtubeId}
                tags={rv.data.tags}
                tabUrl={rv.data.tabUrl}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <!-- VideoObject Structured Data -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VideoObject",
      "name": title,
      "description": description,
      "thumbnailUrl": thumbnailUrl,
      "uploadDate": publishDate.toISOString().split('T')[0],
      ...(duration && { "duration": duration }),
      "contentUrl": watchUrl,
      "embedUrl": embedUrl,
      "author": {
        "@type": "Person",
        "name": "Jordan Hilario",
        "url": "https://jordanhilario.com"
      },
      "publisher": {
        "@type": "Person",
        "name": "Jordan Hilario",
        "url": "https://jordanhilario.com"
      }
    })} />
  </Fragment>
</BaseLayout>

<style>
  .video-player-wrapper {
    background-color: var(--color-bg-dark);
    padding: 2rem 0;
  }

  .video-info-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 3rem;
    padding: 3rem 0;
  }

  .video-info-main h1 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    text-transform: none;
    letter-spacing: normal;
    margin-bottom: 1rem;
  }

  .video-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .video-artist {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .video-date {
    color: var(--color-text-muted);
  }

  .video-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: 2rem;
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .video-body {
    margin-bottom: 2rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .video-body :global(p) {
    margin-bottom: 0.75rem;
  }

  .video-body :global(strong) {
    color: var(--color-text);
  }

  /* Sidebar */
  .video-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .tab-card,
  .subscribe-card {
    padding: 2rem;
    border: 1px solid var(--color-border);
  }

  .tab-card {
    border-color: var(--color-accent);
    background-color: #fef2f2;
  }

  .tab-card h3,
  .subscribe-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .tab-card p,
  .subscribe-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  /* Related */
  .related-section {
    background-color: var(--color-bg-muted);
  }

  @media (max-width: 768px) {
    .video-info-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .video-player-wrapper {
      padding: 0;
    }
  }
</style>
