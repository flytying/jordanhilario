---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/fingerstyle-videos', label: 'Videos' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo">Jordan Hilario</a>

    <nav class="nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="https://www.youtube.com/@JordanHilarioFingerstyle"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link nav-yt"
            aria-label="YouTube Channel"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Mobile menu -->
    <details class="mobile-menu">
      <summary class="hamburger" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <nav class="mobile-nav" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="mobile-nav-link">{link.label}</a>
        ))}
        <a
          href="https://www.youtube.com/@JordanHilarioFingerstyle"
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-nav-link"
        >
          YouTube
        </a>
      </nav>
    </details>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-dark);
    color: var(--color-text-light);
    height: var(--header-height);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.2s;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active {
    border-bottom-color: var(--color-accent);
  }

  .nav-yt {
    display: flex;
    align-items: center;
  }

  .mobile-menu {
    display: none;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    list-style: none;
    padding: 0.5rem;
  }

  .hamburger::-webkit-details-marker {
    display: none;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text-light);
    transition: transform 0.2s;
  }

  .mobile-nav {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    background-color: var(--color-bg-dark);
    padding: 1rem 1.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 99;
  }

  .mobile-nav-link {
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }
    .mobile-menu {
      display: block;
      position: relative;
    }
  }
</style>
