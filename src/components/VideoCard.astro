---
import { getYouTubeThumbnail } from '../utils/youtube';

interface Props {
  slug: string;
  title: string;
  artist: string;
  youtubeId: string;
  tags?: string[];
  tabUrl?: string;
}

const { slug, title, artist, youtubeId, tags = [], tabUrl } = Astro.props;
const thumbnail = getYouTubeThumbnail(youtubeId, 'mq');
---

<a href={`/fingerstyle-videos/${slug}`} class="video-card">
  <div class="video-card-thumb">
    <img
      src={thumbnail}
      alt={title}
      width="320"
      height="180"
      loading="lazy"
    />
    <div class="play-icon">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/>
        <polygon points="19,14 36,24 19,34" fill="white"/>
      </svg>
    </div>
    {tabUrl && <span class="tab-badge">Tab Available</span>}
  </div>
  <div class="video-card-info">
    <h3 class="video-card-title">{title}</h3>
    <p class="video-card-artist">{artist}</p>
    {tags.length > 0 && (
      <div class="video-card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .video-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .video-card:hover {
    transform: translateY(-4px);
  }

  .video-card-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-bg-muted);
  }

  .video-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .video-card:hover .video-card-thumb img {
    transform: scale(1.05);
  }

  .play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .video-card:hover .play-icon {
    opacity: 1;
  }

  .tab-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background-color: var(--color-accent);
    color: white;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.625rem;
  }

  .video-card-info {
    padding: 1rem 0;
  }

  .video-card-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: none;
    letter-spacing: normal;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .video-card-artist {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .video-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
</style>
